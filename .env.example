# ──────────────────────────────────────────────
# Sales Insight Automator — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit the real .env to version control.
# ──────────────────────────────────────────────

# ── LLM ────────────────────────────────────────
# Primary: Google Gemini API key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Fallback: Groq API key (used if Gemini fails)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# ── Email (Gmail SMTP) ─────────────────────────
# Your full Gmail address
GMAIL_USER=

# An App Password (NOT your account password).
# Create one at: https://myaccount.google.com/apppasswords
# You must have 2FA enabled on the account.
GMAIL_APP_PASSWORD=

# ── Security ───────────────────────────────────
# The URL the frontend is served from (used for CORS whitelist).
# Local dev:   http://localhost:3000
# Production:  https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Frontend ───────────────────────────────────
# The URL the frontend uses to reach the backend API.
# Local dev:   http://localhost:8000
# Production:  https://your-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Upload limits ──────────────────────────────
# Maximum file upload size in megabytes
MAX_FILE_MB=5
